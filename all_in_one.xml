<?xml version="1.0" encoding="UTF-8"?>
<root version="1.0">
  <metadata>
    <title>FusionBoa Project</title>
    <author>FusionBoa Team</author>
    <created>2026-01-01</created>
    <dependencies>
      <dependency name="python" version="3.12" />
      <dependency name="node" version="22" />
      <dependency name="go" version="1.22" />
    </dependencies>
    <build>
      <step id="lint">
        <command>fusionboa check</command>
        <step id="test">
          <command>fusionboa test</command>
        </step>
        <step id="build">
          <command>fusionboa build</command>
        </step>
      </step>
    </build>
  </metadata>
</root>