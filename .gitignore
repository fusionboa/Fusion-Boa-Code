# FusionBoa Language - # Python cache files
__pycache__/
*.pyc
*.pyo

# ================================

# Python bytecode & cache
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Generated output from fusionboa build (compiled artifacts only)
# Ignore .py files in ROOT only (not in subdirectories)
/*.py
!setup.py
!install.py
!fusionboa.py

# Keep all source .py files in fusionboa_lang/
!fusionboa_lang/**/*.py

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Virtual environments
venv/
env/
.venv/
.env/

# Node (for JS/TS targets)
node_modules/

# Rust (for Rust targets)
target/

# Go (for Go targets)
*.exe

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Nul device file (accidental creation)
nul

# Temp files
*.tmp
*.temp
