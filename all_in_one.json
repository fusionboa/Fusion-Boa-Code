{
  "app": "FusionBoa",
  "version": "0.3.0",
  "description": "Polyglot programming language",
  "features": [
    "multi-target",
    "english-syntax",
    "zero-clutter"
  ],
  "config": {
    "theme": "dark",
    "languages": 14,
    "auto_detect": true
  },
  "supported": {
    "programming": [
      "python",
      "js",
      "go",
      "rust",
      "cpp",
      "java",
      "ruby"
    ],
    "markup": [
      "html",
      "css",
      "json",
      "yaml",
      "toml",
      "xml"
    ]
  }
}